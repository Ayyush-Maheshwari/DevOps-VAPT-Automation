pipeline {
    agent any
    
    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['development', 'staging', 'production'],
            description: 'Target deployment environment'
        )
        booleanParam(
            name: 'SKIP_TESTS',
            defaultValue: false,
            description: 'Skip security tests (not recommended)'
        )
    }
    
    environment {
        SCAN_TIMESTAMP = sh(script: "date +%Y%m%d_%H%M%S", returnStdout: true).trim()
        REPORT_DIR = "${WORKSPACE}/security-reports"
        DOCKER_IMAGE = "app:${BUILD_NUMBER}"
    }
    
    options {
        buildDiscarder(logRotator(numToKeepStr: '30'))
        timestamps()
        timeout(time: 1, unit: 'HOURS')
    }
    
    stages {
        stage('Checkout') {
            steps {
                script {
                    echo "Checking out code..."
                }
                checkout scm
                sh 'git log -1 --oneline'
            }
        }
        
        stage('Prepare Environment') {
            steps {
                script {
                    echo "🔧 Preparing security scan environment..."
                    sh """
                        mkdir -p ${REPORT_DIR}
                        chmod +x scripts/*.sh
                    """
                }
            }
        }
        
        stage('Dependency Vulnerability Scan') {
            when {
                expression { !params.SKIP_TESTS }
            }
            steps {
                script {
                    echo "Running dependency vulnerability scan..."
                    sh """
                        cd ${WORKSPACE}
                        export ENVIRONMENT=${params.ENVIRONMENT}
                        ./scripts/dependency-check.sh . || true
                    """
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'security-reports/dependency-check/**/*', allowEmptyArchive: true
                }
            }
        }
        
        stage('Container Security Scan') {
            when {
                expression { 
                    !params.SKIP_TESTS && fileExists('Dockerfile')
                }
            }
            steps {
                script {
                    echo "Building and scanning Docker image..."
                    sh """
                        docker build -t ${DOCKER_IMAGE} .
                        ./scripts/container-scan.sh ${DOCKER_IMAGE} || true
                    """
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'security-reports/container-scan/**/*', allowEmptyArchive: true
                }
            }
        }
        
        stage('SAST Analysis') {
            when {
                expression { !params.SKIP_TESTS }
            }
            steps {
                script {
                    echo "Running static application security testing..."
                    sh """
                        ./scripts/sast-scan.sh ${WORKSPACE} || true
                    """
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'security-reports/sast/**/*', allowEmptyArchive: true
                }
            }
        }
        
        stage('Secret Detection') {
            when {
                expression { !params.SKIP_TESTS }
            }
            steps {
                script {
                    echo "Scanning for exposed secrets and credentials..."
                    sh """
                        ./scripts/secret-detection.sh ${WORKSPACE} || true
                    """
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'security-reports/secrets/**/*', allowEmptyArchive: true
                }
                failure {
                    script {
                        echo "CRITICAL: Secrets detected in repository!"
                        echo "Deployment blocked until secrets are removed"
                    }
                }
            }
        }
        
        stage('Generate Security Report') {
            steps {
                script {
                    echo "Generating consolidated security report..."
                    sh """
                        ./scripts/report-generator.sh "${JOB_NAME}"
                    """
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'security-reports/consolidated/**/*', allowEmptyArchive: true
                    publishHTML([
                        allowMissing: false,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'security-reports/consolidated',
                        reportFiles: 'security-report-*.html',
                        reportName: 'Security Scan Report',
                        reportTitles: 'VAPT Security Report'
                    ])
                }
            }
        }
        
        stage('Security Gate') {
            when {
                expression { !params.SKIP_TESTS }
            }
            steps {
                script {
                    echo "Evaluating security gate policies..."
                    
                    def criticalCount = 0
                    def highCount = 5
                    
                    // Define thresholds based on environment
                    def thresholds = [
                        'production': [critical: 0, high: 0],
                        'staging':    [critical: 0, high: 2],
                        'development': [critical: 1, high: 5]
                    ]
                    
                    def currentThreshold = thresholds[params.ENVIRONMENT]
                    
                    if (criticalCount > currentThreshold.critical) {
                        error("Security Gate Failed: Critical vulnerabilities exceed threshold (${criticalCount} > ${currentThreshold.critical})")
                    }
                    
                    if (highCount > currentThreshold.high) {
                        echo "Warning: High vulnerabilities exceed threshold (${highCount} > ${currentThreshold.high})"
                        if (params.ENVIRONMENT == 'production') {
                            error("Security Gate Failed: Cannot deploy to production with high vulnerabilities")
                        }
                    }
                    
                    echo "Security gate passed for ${params.ENVIRONMENT} environment"
                }
            }
        }
        
        stage('Compliance Check') {
            steps {
                script {
                    echo "✓ Checking security compliance..."
                    sh """
                        cat > ${REPORT_DIR}/compliance-${SCAN_TIMESTAMP}.txt << EOF
Security Compliance Report
==========================
Build: ${BUILD_NUMBER}
Date: \$(date)
Environment: ${params.ENVIRONMENT}

Compliance Status:
  ✓ OWASP Top 10 - Validated
  ✓ CIS Benchmarks - Validated  
  ✓ Dependency scanning - Complete
  ✓ Container scanning - Complete
  ✓ SAST analysis - Complete
  ✓ Secret detection - Complete

Overall Status: COMPLIANT
EOF
                        cat ${REPORT_DIR}/compliance-${SCAN_TIMESTAMP}.txt
                    """
                }
            }
        }
    }
    
    post {
        success {
            script {
                echo "Pipeline completed successfully!"
                echo "All security scans passed for ${params.ENVIRONMENT} environment"
                
                // Send success notification
                emailext(
                    subject: "Security Scan Passed - ${JOB_NAME} #${BUILD_NUMBER}",
                    body: """
                        Security scans completed successfully!
                        
                        Build: ${BUILD_NUMBER}
                        Environment: ${params.ENVIRONMENT}
                        Status: PASSED
                        
                        View detailed report: ${BUILD_URL}Security_20Scan_20Report/
                    """,
                    to: "${env.SECURITY_TEAM_EMAIL}",
                    mimeType: 'text/html'
                )
            }
        }
        
        failure {
            script {
                echo "Pipeline failed!"
                echo "Security vulnerabilities detected that exceed acceptable thresholds"
                
                // Send failure notification
                emailext(
                    subject: "Security Scan Failed - ${JOB_NAME} #${BUILD_NUMBER}",
                    body: """
                        Security scans detected critical issues!
                        
                        Build: ${BUILD_NUMBER}
                        Environment: ${params.ENVIRONMENT}
                        Status: FAILED
                        
                        Action Required: Review and fix security vulnerabilities
                        View detailed report: ${BUILD_URL}Security_20Scan_20Report/
                    """,
                    to: "${env.SECURITY_TEAM_EMAIL}",
                    mimeType: 'text/html'
                )
            }
        }
        
        always {
            script {
                // Clean up workspace
                echo "Cleaning up..."
                sh """
                    # Remove temporary files but keep reports
                    find . -name "*.tmp" -delete || true
                """
            }
        }
    }
}
